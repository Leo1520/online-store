@startuml Diagrama_Despliegue_Simple

skinparam backgroundColor #FAFAFA
skinparam fontSize 10

node "Cliente" as Client {
    artifact "Navegador\n(JS/Bootstrap)" as Browser
}

node "Internet" as Net {
}

node "Servidor Web\nApache" as WebServer {
    artifact "HTML/CSS/Assets" as Assets
}

node "Servidor PHP" as AppServer {
    component "Controladores" as Controllers {
        artifact "Cliente, Admin" as Ctrls
    }
    component "Modelos" as Models {
        artifact "Producto, Cliente,\nCuenta, Venta" as Mdls
    }
    component "Servicios" as Services {
        artifact "Validación, Email" as Svcs
    }
}

node "MySQL\nBase Datos" as DB {
    database "mydb" as DBData
}

node "Archivos" as Files {
    artifact "Imágenes\nFacturas\nLogs" as FileData
}

node "Externos" as External {
    artifact "Email API" as ExtAPI
}

Client --> Net: HTTP/HTTPS:443
Net --> WebServer: Solicitud
WebServer --> AppServer: PHP
AppServer --> DB: PDO
AppServer --> Files: Lectura/Escritura
AppServer --> External: Notificaciones

Controllers --> Models: Utiliza
Models --> Services: Utiliza

note right of DB
  Puerto: 3306
  Pool: 50 conexiones
  Backup: Diario 2 AM
end note

note right of AppServer
  PHP 7.4+
  CPU: 4 cores
  RAM: 8 GB
end note

@enduml
