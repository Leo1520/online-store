@startuml Diagrama_de_Secuencia_Proceso_Compra

!define ACTOR_COLOR #E3F2FD
!define PARTICIPANT_COLOR #F3E5F5
!define DB_COLOR #FFF3E0

skinparam backgroundColor #FAFAFA
skinparam sequenceActorBackgroundColor ACTOR_COLOR
skinparam sequenceParticipantBackgroundColor PARTICIPANT_COLOR
skinparam databaseBackgroundColor DB_COLOR
skinparam arrowColor #01579B

actor Cliente
participant "Navegador\n(Frontend)" as Frontend
participant "InicioControlador /\nCarritoControlador" as CarritoCtrl
participant "ProductoControlador" as ProdCtrl
participant "PagoControlador\n+ VentaModelo" as PagoCtrl
participant "NotaVentaModelo /\nFacturaControlador" as NotaVenta
database "MySQL\n(Base de Datos)" as BD

== 1. Búsqueda y Visualización de Productos ==

Cliente -> Frontend: Accede a catálogo
Frontend -> CarritoCtrl: GET /?pagina=inicio
CarritoCtrl -> BD: CALL sp_listar_productos_con_stock_total()
BD -->> CarritoCtrl: Productos con stock agregado
CarritoCtrl -->> Frontend: Array productos
Frontend -->> Cliente: Muestra catálogo

== 2. Filtrado y Búsqueda ==

Cliente -> Frontend: Selecciona filtros\n(categoría, precio)
Frontend -> ProdCtrl: GET /?pagina=inicio\n&nombre=X&codCategoria=1\n&precioMin=0&precioMax=0
ProdCtrl -> BD: CALL sp_buscar_productos\n(nombre, codCategoria, precioMin, precioMax)
BD -->> ProdCtrl: Productos filtrados (estado=activo)
ProdCtrl -->> Frontend: Array resultados
Frontend -->> Cliente: Muestra productos filtrados

== 3. Ver Detalle de Producto ==

Cliente -> Frontend: Click en producto
Frontend -> ProdCtrl: GET /?pagina=producto&id=123
ProdCtrl -> BD: CALL sp_obtener_producto_por_id(123)
note right of BD
  SP retorna producto + stock total
  (JOIN con DetalleProductoSucursal,
  Marca, Categoria, Industria)
end note
BD -->> ProdCtrl: Producto con stock disponible
ProdCtrl -->> Frontend: Datos producto
Frontend -->> Cliente: Muestra detalle producto

== 4. Agregar al Carrito ==

Cliente -> Frontend: Click "Agregar al carrito"
Frontend -> CarritoCtrl: GET /?pagina=carrito\n&accion=agregar&id=123
CarritoCtrl -> BD: CALL sp_obtener_producto_por_id(123)
BD -->> CarritoCtrl: Producto con stock actual
note right of CarritoCtrl
  Validar: producto activo
  Guardar en $_SESSION['carrito']
  [{id_producto, cantidad}]
end note
CarritoCtrl -> Frontend: Redirección con sesión actualizada
Frontend -->> Cliente: Confirma "Producto agregado"

== 5. Modificar Carrito ==

Cliente -> Frontend: Abre carrito
Frontend -> CarritoCtrl: GET /?pagina=carrito
loop Para cada item en $_SESSION['carrito']
    CarritoCtrl -> BD: CALL sp_obtener_producto_por_id(id)
    BD -->> CarritoCtrl: Datos producto + precioVigente
end
CarritoCtrl -->> Frontend: Items con subtotales calculados
Frontend -->> Cliente: Muestra ítems y total

Cliente -> Frontend: Modifica cantidad / elimina item
Frontend -> CarritoCtrl: GET /?pagina=carrito\n&accion=eliminar&id=123
CarritoCtrl -> CarritoCtrl: Actualiza $_SESSION['carrito']
CarritoCtrl -->> Frontend: Carrito actualizado
Frontend -->> Cliente: Muestra nuevo total

== 6. Proceder al Pago ==

Cliente -> Frontend: Click "Proceder al pago"
Frontend -> PagoCtrl: GET /?pagina=pago
note right of PagoCtrl
  Requiere sesión de usuario activa
  Requiere carrito no vacío
end note
loop Para cada item en carrito
    PagoCtrl -> BD: CALL sp_obtener_producto_por_id(id)
    BD -->> PagoCtrl: Datos + precioVigente
end
PagoCtrl -->> Frontend: Vista resumen de pago
Frontend -->> Cliente: Muestra form pago\n(tarjeta o QR demo)

== 7. Validar y Procesar Pago ==

Cliente -> Frontend: Selecciona método y confirma
Frontend -> PagoCtrl: POST /?pagina=pago&metodo=tarjeta
PagoCtrl -> BD: CALL sp_obtener_ci_cliente_por_usuario(usuario)
BD -->> PagoCtrl: CI del cliente
note right of PagoCtrl
  VentaModelo::registrarVenta()
  inicia BEGIN TRANSACTION
end note

== 8. Registrar Venta ==

PagoCtrl -> BD: CALL sp_crear_nota_venta(ciCliente, @nro)
BD -->> PagoCtrl: @nro = 1001\n(INSERT NotaVenta estado='pendiente')

loop Para cada item del carrito
    PagoCtrl -> BD: CALL sp_existe_producto(codProducto)
    BD -->> PagoCtrl: existe = 1
    PagoCtrl -> BD: CALL sp_insertar_detalle_venta\n(nroVenta, codProducto, item, cantidad)
    BD -->> PagoCtrl: Detalle registrado
    PagoCtrl -> BD: CALL sp_descontar_stock_producto\n(codProducto, cantidad)
    BD -->> PagoCtrl: Stock descontado por sucursal
end

PagoCtrl -> BD: COMMIT
BD -->> PagoCtrl: Transacción completada
PagoCtrl -->> Frontend: Redirect /?pagina=pago_exitoso&nro=1001

== 9. Mostrar Confirmación ==

Frontend -->> Cliente: Pantalla pago exitoso\nMuestra:\n✓ Número venta: 1001\n✓ Fecha: 2026-05-05\n✓ Opción descargar recibo

Cliente -> Frontend: Click "Ver Recibo"
Frontend -> NotaVenta: GET /?pagina=factura&nro=1001
NotaVenta -> BD: CALL sp_detalle_venta(1001)
BD -->> NotaVenta: Items de la venta
NotaVenta -> BD: SELECT nv.nro, nv.fechaHora,\ncl.nombres, cl.correo...\nFROM NotaVenta JOIN Cliente\nWHERE nro=1001
BD -->> NotaVenta: Cabecera venta + datos cliente
NotaVenta -->> Frontend: Vista factura HTML
Frontend -->> Cliente: Muestra recibo en pantalla

== 10. Actualizar Historial ==

Cliente -> Frontend: Accede a Mi Cuenta
Frontend -> NotaVenta: GET /?pagina=mi_cuenta
NotaVenta -> BD: CALL sp_obtener_cliente_por_usuario(usuario)
BD -->> NotaVenta: Datos perfil cliente
NotaVenta -> BD: CALL sp_historial_compras_cliente(usuario)
BD -->> NotaVenta: Historial de compras con totales
loop Para cada compra en historial
    NotaVenta -> BD: CALL sp_detalle_venta(nro)
    BD -->> NotaVenta: Items de la compra
end
NotaVenta -->> Frontend: Perfil + historial completo
Frontend -->> Cliente: Perfil muestra\nÚltima compra: $449.96

@enduml
