<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.1"
         xmlns:xmi="http://schema.omg.org/spec/XMI/2.1"
         xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML">

  <uml:Model xmi:id="_model" name="EcommerceVentas">
    <packagedElement xmi:type="uml:Interaction" xmi:id="_int" name="DiagramaSecuenciaVentasYPago">

      <!-- ===== PARTICIPANTES (Lifelines) ===== -->
      <lifeline xmi:id="_ll1" name="Usuario"/>
      <lifeline xmi:id="_ll2" name="index.php (Router)"/>
      <lifeline xmi:id="_ll3" name="PagoControlador"/>
      <lifeline xmi:id="_ll4" name="Venta (Modelo)"/>
      <lifeline xmi:id="_ll5" name="Producto (Modelo)"/>
      <lifeline xmi:id="_ll6" name="MySQL (Stored Procs)"/>

      <!-- ===== MENSAJES ===== -->
      <!-- Seccion 1: GET - Vista de Pago -->
      <message xmi:id="_msg01" name="GET ?pagina=pago"                                         messageSort="synchCall" sendEvent="_mos01s" receiveEvent="_mos01r"/>
      <message xmi:id="_msg02" name="manejar() [GET]"                                          messageSort="synchCall" sendEvent="_mos02s" receiveEvent="_mos02r"/>
      <message xmi:id="_msg_empty" name="redirect carrito (carrito vacio)"                     messageSort="reply"     sendEvent="_mos_emps" receiveEvent="_mos_empr"/>
      <message xmi:id="_msg03" name="obtenerPorId(id)"                                         messageSort="synchCall" sendEvent="_mos03s" receiveEvent="_mos03r"/>
      <message xmi:id="_msg04" name="CALL sp_obtener_producto_por_id(id)"                      messageSort="synchCall" sendEvent="_mos04s" receiveEvent="_mos04r"/>
      <message xmi:id="_msg05" name="{nombre, precio, stock, imagen}"                          messageSort="reply"     sendEvent="_mos05s" receiveEvent="_mos05r"/>
      <message xmi:id="_msg06" name="$producto"                                                messageSort="reply"     sendEvent="_mos06s" receiveEvent="_mos06r"/>
      <message xmi:id="_msg07" name="$items, $total, $sinStock"                                messageSort="reply"     sendEvent="_mos07s" receiveEvent="_mos07r"/>
      <message xmi:id="_msg08" name="render pago.php (tabla + alertas stock)"                  messageSort="reply"     sendEvent="_mos08s" receiveEvent="_mos08r"/>

      <!-- Seccion 2: POST - Completar Compra / Registrar Venta -->
      <message xmi:id="_msg09" name="POST ?pagina=pago [Completar Compra]"                     messageSort="synchCall" sendEvent="_mos09s" receiveEvent="_mos09r"/>
      <message xmi:id="_msg10" name="manejar() [POST]"                                         messageSort="synchCall" sendEvent="_mos10s" receiveEvent="_mos10r"/>
      <message xmi:id="_msg_noses" name="redirect login (sin sesion)"                          messageSort="reply"     sendEvent="_mos_nss" receiveEvent="_mos_nsr"/>
      <message xmi:id="_msg11" name="registrarVenta($carrito, $usuario)"                       messageSort="synchCall" sendEvent="_mos11s" receiveEvent="_mos11r"/>
      <message xmi:id="_msg12" name="CALL sp_obtener_ci_cliente_por_usuario($usuario)"         messageSort="synchCall" sendEvent="_mos12s" receiveEvent="_mos12r"/>
      <message xmi:id="_msg13" name="$ci (CI del cliente)"                                     messageSort="reply"     sendEvent="_mos13s" receiveEvent="_mos13r"/>
      <message xmi:id="_msg_noci" name="return false (CI no encontrado)"                       messageSort="reply"     sendEvent="_mos_ncis" receiveEvent="_mos_ncir"/>
      <message xmi:id="_msg14" name="BEGIN TRANSACTION"                                        messageSort="synchCall" sendEvent="_mos14s" receiveEvent="_mos14r"/>
      <message xmi:id="_msg15" name="CALL sp_crear_nota_venta($ci)"                            messageSort="synchCall" sendEvent="_mos15s" receiveEvent="_mos15r"/>
      <message xmi:id="_msg16" name="$nroVenta"                                                messageSort="reply"     sendEvent="_mos16s" receiveEvent="_mos16r"/>
      <message xmi:id="_msg17" name="CALL sp_existe_producto($codProducto)"                    messageSort="synchCall" sendEvent="_mos17s" receiveEvent="_mos17r"/>
      <message xmi:id="_msg18" name="existe=1"                                                 messageSort="reply"     sendEvent="_mos18s" receiveEvent="_mos18r"/>
      <message xmi:id="_msg19" name="CALL sp_insertar_detalle_venta(nroVenta, codProd, item, cant)" messageSort="synchCall" sendEvent="_mos19s" receiveEvent="_mos19r"/>
      <message xmi:id="_msg20" name="ok"                                                       messageSort="reply"     sendEvent="_mos20s" receiveEvent="_mos20r"/>
      <message xmi:id="_msg21" name="CALL sp_descontar_stock_producto($codProd, $cantidad)"    messageSort="synchCall" sendEvent="_mos21s" receiveEvent="_mos21r"/>
      <message xmi:id="_msg22" name="ok / Exception si stock insuficiente"                     messageSort="reply"     sendEvent="_mos22s" receiveEvent="_mos22r"/>
      <message xmi:id="_msg_commit"   name="COMMIT"                                            messageSort="synchCall" sendEvent="_mos_cs"  receiveEvent="_mos_cr"/>
      <message xmi:id="_msg_rollback" name="ROLLBACK (Throwable capturado)"                    messageSort="synchCall" sendEvent="_mos_rs"  receiveEvent="_mos_rr"/>
      <message xmi:id="_msg25" name="$nroVenta (o false si error)"                             messageSort="reply"     sendEvent="_mos25s" receiveEvent="_mos25r"/>
      <message xmi:id="_msg26" name="redirect pago_exitoso / redirect carrito (error)"         messageSort="reply"     sendEvent="_mos26s" receiveEvent="_mos26r"/>
      <message xmi:id="_msg27" name="render pago_exitoso.php"                                  messageSort="reply"     sendEvent="_mos27s" receiveEvent="_mos27r"/>

      <!-- ===== FRAGMENTOS EN ORDEN (definen la secuencia) ===== -->

      <!-- 1: Usuario → Router GET pago -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos01s" covered="_ll1" message="_msg01"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos01r" covered="_ll2" message="_msg01"/>

      <!-- 2: Router → PagoControlador manejar() -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos02s" covered="_ll2" message="_msg02"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos02r" covered="_ll3" message="_msg02"/>

      <!-- ALT 1: carrito vacio vs con productos -->
      <fragment xmi:type="uml:CombinedFragment" xmi:id="_cf1" interactionOperator="alt">
        <covered xmi:idref="_ll3"/>
        <covered xmi:idref="_ll5"/>
        <covered xmi:idref="_ll6"/>
        <operand xmi:id="_op1a">
          <guard xmi:id="_g1a">
            <specification xmi:type="uml:LiteralString" xmi:id="_gs1a" value="[carrito vacio]"/>
          </guard>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_emps" covered="_ll3" message="_msg_empty"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_empr" covered="_ll2" message="_msg_empty"/>
        </operand>
        <operand xmi:id="_op1b">
          <guard xmi:id="_g1b">
            <specification xmi:type="uml:LiteralString" xmi:id="_gs1b" value="[carrito con productos]"/>
          </guard>
          <!-- 3: PagoControlador → Producto obtenerPorId -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos03s" covered="_ll3" message="_msg03"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos03r" covered="_ll5" message="_msg03"/>
          <!-- 4: Producto → MySQL -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos04s" covered="_ll5" message="_msg04"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos04r" covered="_ll6" message="_msg04"/>
          <!-- 5: MySQL → Producto (datos) -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos05s" covered="_ll6" message="_msg05"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos05r" covered="_ll5" message="_msg05"/>
          <!-- 6: Producto → PagoControlador -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos06s" covered="_ll5" message="_msg06"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos06r" covered="_ll3" message="_msg06"/>
        </operand>
      </fragment>

      <!-- 7: PagoControlador → Router ($items, $total) -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos07s" covered="_ll3" message="_msg07"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos07r" covered="_ll2" message="_msg07"/>

      <!-- 8: Router → Usuario render pago.php -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos08s" covered="_ll2" message="_msg08"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos08r" covered="_ll1" message="_msg08"/>

      <!-- =========================================================== -->
      <!-- SECCION 2: POST - Completar Compra                           -->
      <!-- =========================================================== -->

      <!-- 9: Usuario → Router POST -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos09s" covered="_ll1" message="_msg09"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos09r" covered="_ll2" message="_msg09"/>

      <!-- 10: Router → PagoControlador manejar() -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos10s" covered="_ll2" message="_msg10"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos10r" covered="_ll3" message="_msg10"/>

      <!-- ALT 2: sin sesion vs sesion activa -->
      <fragment xmi:type="uml:CombinedFragment" xmi:id="_cf2" interactionOperator="alt">
        <covered xmi:idref="_ll3"/>
        <covered xmi:idref="_ll4"/>
        <covered xmi:idref="_ll6"/>
        <operand xmi:id="_op2a">
          <guard xmi:id="_g2a">
            <specification xmi:type="uml:LiteralString" xmi:id="_gs2a" value="[sin sesion activa]"/>
          </guard>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_nss" covered="_ll3" message="_msg_noses"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_nsr" covered="_ll2" message="_msg_noses"/>
        </operand>
        <operand xmi:id="_op2b">
          <guard xmi:id="_g2b">
            <specification xmi:type="uml:LiteralString" xmi:id="_gs2b" value="[sesion activa]"/>
          </guard>

          <!-- 11: PagoControlador → Venta registrarVenta -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos11s" covered="_ll3" message="_msg11"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos11r" covered="_ll4" message="_msg11"/>

          <!-- 12: Venta → MySQL sp_obtener_ci -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos12s" covered="_ll4" message="_msg12"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos12r" covered="_ll6" message="_msg12"/>

          <!-- 13: MySQL → Venta $ci -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos13s" covered="_ll6" message="_msg13"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos13r" covered="_ll4" message="_msg13"/>

          <!-- ALT 3: CI no encontrado -->
          <fragment xmi:type="uml:CombinedFragment" xmi:id="_cf3" interactionOperator="alt">
            <covered xmi:idref="_ll4"/>
            <covered xmi:idref="_ll6"/>
            <operand xmi:id="_op3a">
              <guard xmi:id="_g3a">
                <specification xmi:type="uml:LiteralString" xmi:id="_gs3a" value="[CI no encontrado]"/>
              </guard>
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_ncis" covered="_ll4" message="_msg_noci"/>
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_ncir" covered="_ll3" message="_msg_noci"/>
            </operand>
            <operand xmi:id="_op3b">
              <guard xmi:id="_g3b">
                <specification xmi:type="uml:LiteralString" xmi:id="_gs3b" value="[CI encontrado - continuar]"/>
              </guard>

              <!-- 14: Venta BEGIN TRANSACTION (self-message) -->
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos14s" covered="_ll4" message="_msg14"/>
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos14r" covered="_ll4" message="_msg14"/>

              <!-- 15: Venta → MySQL sp_crear_nota_venta -->
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos15s" covered="_ll4" message="_msg15"/>
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos15r" covered="_ll6" message="_msg15"/>

              <!-- 16: MySQL → Venta $nroVenta -->
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos16s" covered="_ll6" message="_msg16"/>
              <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos16r" covered="_ll4" message="_msg16"/>

              <!-- LOOP: por cada producto en carrito -->
              <fragment xmi:type="uml:CombinedFragment" xmi:id="_cf_loop" interactionOperator="loop">
                <covered xmi:idref="_ll4"/>
                <covered xmi:idref="_ll6"/>
                <operand xmi:id="_op_loop">
                  <guard xmi:id="_g_loop">
                    <specification xmi:type="uml:LiteralString" xmi:id="_gs_loop" value="por cada producto en carrito"/>
                  </guard>
                  <!-- 17: sp_existe_producto -->
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos17s" covered="_ll4" message="_msg17"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos17r" covered="_ll6" message="_msg17"/>
                  <!-- 18: existe=1 -->
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos18s" covered="_ll6" message="_msg18"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos18r" covered="_ll4" message="_msg18"/>
                  <!-- 19: sp_insertar_detalle_venta -->
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos19s" covered="_ll4" message="_msg19"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos19r" covered="_ll6" message="_msg19"/>
                  <!-- 20: ok -->
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos20s" covered="_ll6" message="_msg20"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos20r" covered="_ll4" message="_msg20"/>
                  <!-- 21: sp_descontar_stock_producto -->
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos21s" covered="_ll4" message="_msg21"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos21r" covered="_ll6" message="_msg21"/>
                  <!-- 22: ok / Exception -->
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos22s" covered="_ll6" message="_msg22"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos22r" covered="_ll4" message="_msg22"/>
                </operand>
              </fragment>

              <!-- ALT 4: COMMIT vs ROLLBACK -->
              <fragment xmi:type="uml:CombinedFragment" xmi:id="_cf4" interactionOperator="alt">
                <covered xmi:idref="_ll4"/>
                <covered xmi:idref="_ll6"/>
                <operand xmi:id="_op4a">
                  <guard xmi:id="_g4a">
                    <specification xmi:type="uml:LiteralString" xmi:id="_gs4a" value="[exito - todos los productos procesados]"/>
                  </guard>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_cs" covered="_ll4" message="_msg_commit"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_cr" covered="_ll6" message="_msg_commit"/>
                </operand>
                <operand xmi:id="_op4b">
                  <guard xmi:id="_g4b">
                    <specification xmi:type="uml:LiteralString" xmi:id="_gs4b" value="[error - stock insuficiente u otro]"/>
                  </guard>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_rs" covered="_ll4" message="_msg_rollback"/>
                  <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos_rr" covered="_ll6" message="_msg_rollback"/>
                </operand>
              </fragment>

            </operand>
          </fragment>

          <!-- 25: Venta → PagoControlador $nroVenta -->
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos25s" covered="_ll4" message="_msg25"/>
          <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos25r" covered="_ll3" message="_msg25"/>

        </operand>
      </fragment>

      <!-- 26: PagoControlador → Router redirect -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos26s" covered="_ll3" message="_msg26"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos26r" covered="_ll2" message="_msg26"/>

      <!-- 27: Router → Usuario render pago_exitoso.php -->
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos27s" covered="_ll2" message="_msg27"/>
      <fragment xmi:type="uml:MessageOccurrenceSpecification" xmi:id="_mos27r" covered="_ll1" message="_msg27"/>

    </packagedElement>
  </uml:Model>

</xmi:XMI>
